---
// src/pages/admin.astro
import fs from 'node:fs/promises';
import path from 'node:path';

export const prerender = false; // FUNDAMENTAL para que lea el JSON fresco

// 1. Leemos el JSON actual antes de cargar la página
const jsonPath = path.resolve('./src/data/menu.json');
const fileData = await fs.readFile(jsonPath, 'utf-8');
const menu = JSON.parse(fileData);

// 2. Si viene un mensaje de éxito por URL (opcional)
const mensaje = Astro.url.searchParams.get('status') === 'success' ? '✅ ¡Precios actualizados!' : '';
---

<layout title="Panel de Control - La Rambla">
  <main class="p-8 max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Editar Precios del Menú</h1>
    
    {mensaje && <div class="bg-green-100 text-green-800 p-4 rounded mb-4">{mensaje}</div>}

    <form action="/api/guardar" method="POST" class="space-y-6">
      {menu.map((item, index) => (
        <div class="border p-4 rounded-lg bg-gray-50 shadow-sm">
          <p class="font-bold text-gray-700 mb-2">{item.nombre}</p>
          
          {/* Mantenemos el nombre oculto para saber qué estamos editando */}
          <input type="hidden" name={`items[${index}][nombre]`} value={item.nombre} />
          <input type="hidden" name={`items[${index}][descripcion]`} value={item.descripcion} />
          
          <div class="flex items-center gap-2">
            <label class="text-sm text-gray-500">Precio:</label>
            <input 
              type="number" 
              name={`items[${index}][precio]`} 
              value={item.precio} 
              class="border rounded px-3 py-1 w-32 focus:ring-2 focus:ring-blue-500 outline-none"
              required
            />
          </div>
        </div>
      ))}

      <button 
        type="submit" 
        class="w-full bg-black text-white py-3 rounded-xl font-bold hover:bg-gray-800 transition"
      >
        Guardar Cambios y Generar PDF
      </button>
    </form>
    
    <div class="mt-8 pt-6 border-t text-center">
      <a href="/menu.pdf" target="_blank" class="text-blue-600 underline">
        🔗 Ver PDF actual para el QR
      </a>
    </div>
  </main>
</layout>
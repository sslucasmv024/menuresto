---
// src/pages/menu-pdf.astro
import fs from 'node:fs/promises';
import path from 'node:path';

// 1. ESTO ES VITAL: Dice a Astro que NO use versiones viejas
export const prerender = false;

// 2. LEER EL ARCHIVO REAL DEL DISCO
const jsonPath = path.resolve('./src/data/menu.json');
const fileData = await fs.readFile(jsonPath, 'utf-8');
const menu = JSON.parse(fileData);
---

<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white p-10">
    <h1 class="text-3xl font-bold border-b-2 pb-4 mb-6">La Rambla Grill</h1>
    <div class="space-y-4">
        {menu.map((item) => (
            <div class="flex justify-between items-baseline border-b border-dotted border-gray-300">
                <div>
                    <span class="text-xl font-bold uppercase">{item.nombre}</span>
                    <p class="text-sm text-gray-500 italic">{item.descripcion}</p>
                </div>
                <span class="text-xl font-black">${item.precio}</span>
            </div>
        ))}
    </div>
</body>
</html>
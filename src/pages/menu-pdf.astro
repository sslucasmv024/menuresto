---
// src/pages/menu-pdf.astro
import fs from 'node:fs/promises';
import path from 'node:path';

// 1. IMPORTANTE: Esto evita que Render guarde una versión vieja en cache
export const prerender = false;

// 2. Leemos el archivo directamente del disco (No usamos 'import')
const jsonPath = path.resolve('./src/data/menu.json');
const fileData = await fs.readFile(jsonPath, 'utf-8');
const menu = JSON.parse(fileData);

// Opcional: Log para ver en Render qué precio está leyendo el robot
console.log("🤖 El robot está leyendo el menú con estos datos:", menu[0].precio);
---

<html>
  <body>
    {menu.map(item => (
      <div>{item.nombre}: ${item.precio}</div>
    ))}
  </body>
</html>